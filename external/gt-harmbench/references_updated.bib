@inproceedings{wangEnhancingCybersecurityEvaluation2025,
 abstract = {This study proposes a comprehensive cybersecurity assessment model that integrates the Global Cybersecurity Index (GCI), Cybersecurity Engagement Index (CEI), and Network Security Index (NCSI). Through a game theory-based assessment methodology combined with a multilayer perceptron (MLP) model, the model evaluates national cybersecurity capabilities in four key dimensions: legal, technological, organizational, and cooperative. The MLP model is also used to predict future cybersecurity trends. The results provide an important reference for policymakers to optimize national cybersecurity strategies and strengthen global cybersecurity governance efforts.},
 address = {New York, NY, USA},
 author = {Wang, Haoran and Hu, Xiaoyu and Xu, Yifan and Ding, Jianbo and Zhao, Chenyu and Jiang, Bingchen and Zhang, Huakun},
